{
  "name": "@jakoblierman/js-tooling",
  "description": "Personal JavaScript tools and configurations",
  "version": "0.0.1",
  "author": {
    "name": "Jakob Lierman",
    "email": "jakob.lierman@gmail.com",
    "url": "https://jakoblierman.be"
  },
  "repository": "JakobLierman/js-tooling.git",
  "bugs": "https://github.com/JakobLierman/js-tooling/issues",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "clean": "rm -rf .turbo coverage && turbo run clean",
    "dev": "turbo run dev",
    "format": "pnpm build --filter=@jakoblierman/prettier-config... && prettier --write --ignore-unknown .",
    "lint": "pnpm build --filter=@jakoblierman/eslint-config... && eslint",
    "prepare": "husky",
    "start": "turbo run start",
    "test": "turbo run test:root",
    "test:root": "vitest run"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@jakoblierman/commitlint-config": "workspace:*",
    "@jakoblierman/eslint-config": "workspace:*",
    "@jakoblierman/prettier-config": "workspace:*",
    "@jakoblierman/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16",
    "prettier": "^3.8.1",
    "syncpack": "^14.2.1",
    "tsx": "^4.21.0",
    "turbo": "~2.8.20",
    "vitest": "^4.1.1",
    "yaml": "^2.8.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2"
    }
  }
}
