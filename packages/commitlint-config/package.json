{
  "name": "@jakoblierman/commitlint-config",
  "description": "Commit lint configuration",
  "keywords": [
    "commitlint",
    "commitlint-config",
    "conventional-changelog"
  ],
  "version": "4.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist .turbo",
    "dev": "tsdown --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@commitlint/config-conventional": "~20.5.0",
    "@commitlint/types": "~20.5.0"
  },
  "devDependencies": {
    "@commitlint/lint": "^20.5.0",
    "@commitlint/load": "^20.5.0",
    "@jakoblierman/tsconfig": "workspace:*",
    "@types/node": "^24",
    "tsdown": "^0.21.5",
    "typescript": "~5.9",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@commitlint/cli": "^20.5.0"
  }
}
