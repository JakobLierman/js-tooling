{
  "name": "@jakoblierman/prettier-config",
  "description": "Personal Prettier configuration",
  "keywords": [
    "prettier",
    "prettier-config"
  ],
  "version": "2.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist .turbo",
    "dev": "tsdown --watch",
    "test": "vitest"
  },
  "dependencies": {
    "prettier-plugin-embed": "~0.5.1",
    "prettier-plugin-packagejson": "~3.0.2",
    "prettier-plugin-prisma": "~5.0.0",
    "prettier-plugin-properties": "~0.3.1",
    "prettier-plugin-sh": "~0.18.0",
    "prettier-plugin-sql": "~0.20.0",
    "prettier-plugin-tailwindcss": "~0.7.2"
  },
  "devDependencies": {
    "@jakoblierman/tsconfig": "workspace:*",
    "tsdown": "^0.21.5",
    "typescript": "~5.9",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "prettier": "^3.8.1"
  }
}
