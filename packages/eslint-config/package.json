{
  "name": "@jakoblierman/eslint-config",
  "description": "Personal ESLint configuration",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "version": "2.1.1",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "default": "./dist/react.mjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.mts",
      "default": "./dist/nextjs.mjs"
    },
    "./turborepo": {
      "types": "./dist/turborepo.d.mts",
      "default": "./dist/turborepo.mjs"
    },
    "./vitest": {
      "types": "./dist/vitest.d.mts",
      "default": "./dist/vitest.mjs"
    },
    "./jest": {
      "types": "./dist/jest.d.mts",
      "default": "./dist/jest.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist .turbo",
    "dev": "tsdown --watch",
    "test": "vitest"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "~4.7.2",
    "@eslint-react/eslint-plugin": "~5.9.0",
    "@eslint/eslintrc": "~3.3.5",
    "@eslint/js": "~10.0.1",
    "@next/eslint-plugin-next": "~16.2.9",
    "@stylistic/eslint-plugin": "~5.10.0",
    "@vitest/eslint-plugin": "~1.6.20",
    "eslint-config-next": "~16.2.9",
    "eslint-config-prettier": "~10.1.8",
    "eslint-import-resolver-typescript": "~4.4.5",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jest": "~29.15.2",
    "eslint-plugin-jsdoc": "~63.0.2",
    "eslint-plugin-n": "~18.1.0",
    "eslint-plugin-prettier": "~5.5.6",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-regexp": "~3.1.0",
    "eslint-plugin-turbo": "~2.9.18",
    "eslint-plugin-unicorn": "~66.0.0",
    "eslint-plugin-unused-imports": "~4.4.1",
    "typescript-eslint": "~8.61.0"
  },
  "devDependencies": {
    "@jakoblierman/tsconfig": "workspace:*",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24",
    "eslint": "^10.5.0",
    "tsdown": "^0.22.2",
    "typescript": "~6.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "eslint": "^10.5.0"
  }
}
